<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fashionstylefx.CarritoController">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
            <children>
                <Label text="Mi Carrito" />
                
                <VBox fx:id="contenedorProductos" spacing="10.0" />
                
                <Label fx:id="lblSubtotal" text="Subtotal: $0" />
                <Label fx:id="lblEnvio" text="Envio: $10000" />
                <Label fx:id="lblTotal" text="Total: $0" />
                
                <Button fx:id="btnComprar" text="Finalizar compra" />
                <Button fx:id="btnSeguirComprando" text="Seguir comprando" />
                <Button fx:id="btnLimpiar" text="Limpiar carrito" />
                
                <Label fx:id="lblMensaje" text="" />
            </children>
        </VBox>
    </children>
</AnchorPane>