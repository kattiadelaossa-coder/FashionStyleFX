<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" stylesheets="@estilos.css" styleClass="fondo-catalogo" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fashionstylefx.CatalogoController">
    <children>
        <VBox spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="30.0" styleClass="header" prefHeight="70.0" prefWidth="1200.0">
                    <children>
                        <Label styleClass="logo-header" text="FASHIONSTYLE" HBox.hgrow="NEVER" />
                        
                        <TextField fx:id="txtBuscar" promptText="🔍 Buscar productos..." styleClass="barra-busqueda" prefWidth="300.0" />
                        
                        <HBox alignment="CENTER_RIGHT" spacing="20.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="btnPerfil" styleClass="icono-header" text="👤" />
                                <Label fx:id="btnListaDeseos" styleClass="icono-header" text="❤️" />
                                <Label fx:id="btnCarrito" styleClass="icono-header" text="🛒" />
                                <Button fx:id="btnCerrarSesion" text="🚪" styleClass="icono-header" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
                
                <!-- Menú de categorías -->
                <HBox alignment="CENTER" spacing="20.0" styleClass="menu-categoria" prefWidth="1200.0">
                    <children>
                        <Button fx:id="btnInicio" styleClass="boton-categoria, boton-categoria-activo" text="Inicio" />
                        <Button fx:id="btnHombres" styleClass="boton-categoria" text="Hombres" />
                        <Button fx:id="btnMujeres" styleClass="boton-categoria" text="Mujeres" />
                    </children>
                </HBox>
                
                <!-- Contenido principal con ScrollPane -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="20.0" alignment="CENTER">
                            <children>
                                <!-- Grid de productos -->
                                <GridPane fx:id="gridProductos" alignment="CENTER" hgap="20.0" vgap="20.0" />
                                
                                <!-- Mensaje -->
                                <Label fx:id="lblMensaje" styleClass="mensaje-error" text="" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>